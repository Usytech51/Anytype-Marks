{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "1.10.1",
  "default_locale": "fr",
  "browser_specific_settings": {
    "gecko": {
      "id": "anytype-marks@sync.extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png",
    "64": "icons/icon-64.png"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "unlimitedStorage",
    "menus",
    "notifications",
    "alarms",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "src/lib/util.js",
      "src/lib/crypto.js",
      "src/lib/store.js",
      "src/lib/anytype.js",
      "src/lib/queue.js",
      "src/lib/mapper.js",
      "src/lib/sync.js",
      "src/background/background.js"
    ]
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  }
}