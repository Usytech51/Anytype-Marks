  "rulesIntroShort": {
    "message": "Ajoutez automatiquement des tags selon le dossier, le titre ou l'URL du favori. Cliquez sur « ? » pour le guide et les variables dynamiques."
  },
  "rulesHelpTitle": {
    "message": "Aide — Règles de tags automatiques"
  },
  "rulesHelpWhat": {
    "message": "Une règle = des conditions + des tags. Si les conditions correspondent (toutes, ou au moins une, selon le mode choisi), les tags sont ajoutés au favori. Toutes les règles qui correspondent s'appliquent en même temps."
  },
  "rulesHelpWhen": {
    "message": "Les règles s'appliquent : dans le popup dès que vous choisissez un dossier (les tags apparaissent immédiatement, vous pouvez les retirer), quand vous déplacez un favori dans Firefox, à la création d'un favori, et quand un dossier est renommé."
  },
  "rulesHelpVarsTitle": {
    "message": "Variables dynamiques"
  },
  "rulesHelpVars1": {
    "message": "Écrivez <<var>> (ou $$$$var, c'est équivalent) dans une condition pour capturer le nom d'un dossier, puis réutilisez <<var>> dans les tags. La variable capture exactement un niveau de dossier et conserve la casse d'origine."
  },
  "rulesHelpExCond": {
    "message": "Condition : Dossier · contient · Travail/clients/<<client>>"
  },
  "rulesHelpExTag": {
    "message": "Tags à ajouter : <<client>>"
  },
  "rulesHelpExResult": {
    "message": "→ un favori placé dans « Travail/clients/Entreprise1 » reçoit le tag Entreprise1 ; dans « Travail/clients/Dupont », le tag Dupont."
  },
  "rulesHelpVars2": {
    "message": "Plusieurs variables sont possibles (Travail/<<type>>/<<nom>>) et les tags peuvent composer (projet-<<nom>>). Un tag dont la variable n'est pas résolue est ignoré."
  },
  "rulesHelpVars3": {
    "message": "Avec l'opérateur regex, les groupes de capture deviennent <<1>>, <<2>>… et les groupes nommés (?<org>…) deviennent <<org>>. Exemple : URL · regex · github\\.com/(?<org>[\\w-]+)/ avec le tag gh:<<org>>."
  }
