  "rulesIntroShort": {
    "message": "Automatically add tags based on the bookmark's folder, title or URL. Click “?” for the guide and dynamic variables."
  },
  "rulesHelpTitle": {
    "message": "Help — Automatic tag rules"
  },
  "rulesHelpWhat": {
    "message": "A rule = conditions + tags. If the conditions match (all of them, or at least one, depending on the chosen mode), the tags are added to the bookmark. Every matching rule applies at the same time."
  },
  "rulesHelpWhen": {
    "message": "Rules apply: in the popup as soon as you pick a folder (tags appear immediately and can be removed), when you move a bookmark in Firefox, when a bookmark is created, and when a folder is renamed."
  },
  "rulesHelpVarsTitle": {
    "message": "Dynamic variables"
  },
  "rulesHelpVars1": {
    "message": "Write <<var>> (or $$$$var — both are equivalent) in a condition to capture a folder name, then reuse <<var>> in the tags. A variable captures exactly one folder level and keeps the original casing."
  },
  "rulesHelpExCond": {
    "message": "Condition: Folder · contains · Work/clients/<<client>>"
  },
  "rulesHelpExTag": {
    "message": "Tags to add: <<client>>"
  },
  "rulesHelpExResult": {
    "message": "→ a bookmark placed in “Work/clients/Company1” gets the tag Company1; in “Work/clients/Smith”, the tag Smith."
  },
  "rulesHelpVars2": {
    "message": "Multiple variables are allowed (Work/<<type>>/<<name>>) and tags can be composed (project-<<name>>). A tag whose variable is unresolved is skipped."
  },
  "rulesHelpVars3": {
    "message": "With the regex operator, capture groups become <<1>>, <<2>>… and named groups (?<org>…) become <<org>>. Example: URL · regex · github\\.com/(?<org>[\\w-]+)/ with the tag gh:<<org>>."
  }
}